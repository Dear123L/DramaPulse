{
  "openapi": "3.0.1",
  "info": {
    "title": "默认模块",
    "description": "短剧互动激发平台后台服务 —— 基于AI的剧情高光点分析与互动配置生成",
    "version": "1.0.0"
  },
  "tags": [
    {
      "name": "health"
    },
    {
      "name": "episodes"
    },
    {
      "name": "ai-image"
    },
    {
      "name": "ai"
    }
  ],
  "paths": {
    "/video/stream": {
      "get": {
        "summary": "获取第67集视频流",
        "deprecated": false,
        "description": "",
        "operationId": "serve_video",
        "tags": [
          "health"
        ],
        "parameters": [],
        "responses": {
          "200": {
            "description": "返回视频文件流",
            "content": {
              "video/mp4": {
                "schema": {
                  "type": "string",
                  "format": "binary"
                }
              }
            },
            "headers": {}
          },
          "404": {
            "description": "视频文件未找到",
            "headers": {}
          }
        },
        "security": []
      }
    },
    "/episodes": {
      "get": {
        "summary": "获取所有剧集列表",
        "deprecated": false,
        "description": "",
        "operationId": "list_episodes",
        "tags": [
          "episodes"
        ],
        "parameters": [],
        "responses": {
          "200": {
            "description": "剧集列表",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/EpisodeBrief"
                  }
                }
              }
            },
            "headers": {}
          }
        },
        "security": []
      }
    },
    "/episodes/{episode_no}": {
      "get": {
        "summary": "获取指定剧集信息",
        "deprecated": false,
        "description": "",
        "operationId": "get_episode",
        "tags": [
          "episodes"
        ],
        "parameters": [
          {
            "name": "episode_no",
            "in": "path",
            "description": "剧集编号，如 67",
            "required": true,
            "example": 0,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "剧集详情",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/EpisodeBrief"
                }
              }
            },
            "headers": {}
          },
          "404": {
            "description": "剧集不存在",
            "headers": {}
          }
        },
        "security": []
      }
    },
    "/episodes/{episode_no}/highlights": {
      "get": {
        "summary": "获取某集所有高光点（App 核心接口）",
        "deprecated": false,
        "description": "",
        "operationId": "get_highlights",
        "tags": [
          "episodes"
        ],
        "parameters": [
          {
            "name": "episode_no",
            "in": "path",
            "description": "剧集编号，如 67",
            "required": true,
            "example": 0,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "高光点列表",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HighlightListResponse"
                }
              }
            },
            "headers": {}
          },
          "404": {
            "description": "剧集不存在",
            "headers": {}
          }
        },
        "security": []
      }
    },
    "/episodes/{episode_no}/highlights/{highlight_id}": {
      "get": {
        "summary": "获取单个高光点详情",
        "deprecated": false,
        "description": "",
        "operationId": "get_highlight",
        "tags": [
          "episodes"
        ],
        "parameters": [
          {
            "name": "episode_no",
            "in": "path",
            "description": "剧集编号，如 67",
            "required": true,
            "example": 0,
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "highlight_id",
            "in": "path",
            "description": "高光点 ID",
            "required": true,
            "example": 0,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "高光点详情",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Highlight"
                }
              }
            },
            "headers": {}
          },
          "404": {
            "description": "高光点不存在",
            "headers": {}
          }
        },
        "security": []
      }
    },
    "/ai/branch-with-image": {
      "post": {
        "summary": "AI 生成剧情分支续写 + 文生图（方案B）",
        "deprecated": false,
        "description": "与 /ai/branch 类似，但额外生成一张文生图。需要配置 STABLE_DIFFUSION_API_KEY 或 DOUBAO_IMAGE_API_KEY。无 Key 时自动生成占位图。",
        "operationId": "generate_story_branch_with_image",
        "tags": [
          "ai-image"
        ],
        "parameters": [],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/BranchRequest"
              },
              "example": {
                "episode_no": 67,
                "highlight_id": 51,
                "branch_id": "A",
                "branch_text": "探查前方暗道"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "AI 续写 + 图片路径",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BranchImageResponse"
                }
              }
            },
            "headers": {}
          },
          "404": {
            "description": "剧集或高光点不存在",
            "headers": {}
          }
        },
        "security": []
      }
    },
    "/ai/branch": {
      "post": {
        "summary": "AI 生成剧情分支续写（方案A：纯文字）",
        "deprecated": false,
        "description": "根据高光点上下文和用户选择的分支，调用豆包AI生成剧情续写。结果会缓存到 branch_results 表。\n\n⚠️ 注意：数据库里第67集高光点 id 范围是 51~75，不是 1~25。请先调用 GET /episodes/67/highlights 获取真实 id。",
        "operationId": "generate_story_branch",
        "tags": [
          "ai"
        ],
        "parameters": [],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/BranchRequest"
              },
              "example": {
                "episode_no": 67,
                "highlight_id": 51,
                "branch_id": "A",
                "branch_text": "探查前方暗道"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "AI 续写结果",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BranchTextResponse"
                }
              }
            },
            "headers": {}
          },
          "404": {
            "description": "剧集或高光点不存在",
            "headers": {}
          }
        },
        "security": []
      }
    }
  },
  "components": {
    "schemas": {
      "EpisodeBrief": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "description": "剧集主键"
          },
          "episode_no": {
            "type": "integer",
            "description": "剧集编号"
          },
          "title": {
            "type": "string",
            "description": "剧集标题"
          },
          "theme": {
            "type": "string",
            "description": "主题标签"
          },
          "total_duration": {
            "type": "integer",
            "description": "视频总时长（秒）"
          },
          "status": {
            "type": "string",
            "enum": [
              "pending",
              "analyzing",
              "done",
              "failed"
            ],
            "description": "分析状态"
          },
          "highlight_count": {
            "type": "integer",
            "description": "高光点总数"
          }
        }
      },
      "Highlight": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "description": "高光点主键（调用 /ai/branch 时需要）"
          },
          "timestamp": {
            "type": "integer",
            "description": "触发时间（秒）"
          },
          "type": {
            "type": "string",
            "description": "场景类型：悬疑/恐惧/危机等"
          },
          "intensity": {
            "type": "integer",
            "description": "情绪强度 1~10"
          },
          "emotion": {
            "type": "string",
            "description": "情绪描述"
          },
          "scene_desc": {
            "type": "string",
            "description": "场景描述"
          },
          "action_desc": {
            "type": "string",
            "description": "角色动作描述"
          },
          "trigger": {
            "type": "object",
            "description": "触发配置 JSON",
            "properties": {}
          },
          "visual_effect": {
            "type": "string",
            "description": "视觉特效类型"
          },
          "particle_type": {
            "type": "string",
            "description": "粒子特效类型"
          },
          "haptic_pattern": {
            "type": "string",
            "description": "震动类型"
          },
          "audio_cue": {
            "type": "string",
            "description": "音效提示"
          },
          "show_branch": {
            "type": "boolean",
            "description": "是否弹出分支弹窗"
          },
          "branch_options": {
            "type": "array",
            "description": "分支选项",
            "items": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "string",
                  "description": "选项标识 A/B/C"
                },
                "text": {
                  "type": "string",
                  "description": "选项文字"
                },
                "consequence": {
                  "type": "string",
                  "description": "后果简述"
                }
              }
            }
          },
          "ai_prompt": {
            "type": "string",
            "description": "AI 续写提示词"
          }
        }
      },
      "HighlightListResponse": {
        "type": "object",
        "properties": {
          "episode_no": {
            "type": "integer"
          },
          "title": {
            "type": "string"
          },
          "theme": {
            "type": "string"
          },
          "total_duration": {
            "type": "integer"
          },
          "highlight_count": {
            "type": "integer"
          },
          "highlights": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Highlight"
            }
          }
        }
      },
      "BranchRequest": {
        "type": "object",
        "required": [
          "highlight_id",
          "branch_id"
        ],
        "properties": {
          "episode_no": {
            "type": "integer",
            "default": 67,
            "description": "剧集编号"
          },
          "highlight_id": {
            "type": "integer",
            "description": "高光点 ID（⚠️ 第67集范围 51~75，不是 1~25）"
          },
          "branch_id": {
            "type": "string",
            "description": "分支选项：A / B / C"
          },
          "branch_text": {
            "type": "string",
            "default": "",
            "description": "用户选择的分支文字，如：探查前方暗道"
          },
          "context": {
            "type": "string",
            "default": "",
            "description": "前端传的场景描述（兼容旧调用）"
          }
        }
      },
      "BranchTextResponse": {
        "type": "object",
        "properties": {
          "branch_id": {
            "type": "string",
            "description": "分支选项 A/B/C"
          },
          "text": {
            "type": "string",
            "description": "AI 续写正文"
          },
          "cached": {
            "type": "boolean",
            "description": "是否来自缓存"
          },
          "token_usage": {
            "type": "integer",
            "description": "消耗 token 数"
          }
        }
      },
      "BranchImageResponse": {
        "type": "object",
        "properties": {
          "branch_id": {
            "type": "string"
          },
          "text": {
            "type": "string",
            "description": "AI 续写正文"
          },
          "image_url": {
            "type": "string",
            "description": "生成的图片 URL（空串表示失败）"
          },
          "result_type": {
            "type": "string",
            "example": "image"
          },
          "cached": {
            "type": "boolean"
          },
          "token_usage": {
            "type": "integer"
          }
        }
      }
    },
    "responses": {},
    "securitySchemes": {}
  },
  "servers": [],
  "security": []
}