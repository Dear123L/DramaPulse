# =============================================================
# DramaPulse 后端 .gitignore
# Git 根目录：backend/
# =============================================================

# =====================
# 敏感配置 —— 禁止推送
# =====================
.env
*.env
!.env.example

# =====================
# 视频 / 音频 / 大文件
# =====================
*.mp4
*.mkv
*.avi
*.mov
*.flv
*.wmv
*.mp3
*.wav
*.aac

# 视频帧截图目录
frames/

# =====================
# AI 生成的多媒体资源
# =====================
multimodal_assets/

# =====================
# Python
# =====================
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg
*.egg-info/
dist/
build/
.eggs/
.venv/
venv/
ENV/
env/
pip-log.txt
.pytest_cache/
.mypy_cache/

# =====================
# IDE / 编辑器
# =====================
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# =====================
# 日志 / 临时文件
# =====================
*.log
*.tmp
*.bak
*.orig
