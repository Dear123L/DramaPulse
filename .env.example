# =============================================================
# DramaPulse 后端环境变量模板
# 复制此文件为 .env，填入真实值后再启动服务
# =============================================================

# MySQL 数据库
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=your_db_user
MYSQL_PASSWORD=your_db_password
MYSQL_DATABASE=drama_pulse

# 豆包 AI（火山方舟）—— 文字续写
# 在 https://console.volcengine.com/ark 获取
AI_API_KEY=your_ark_api_key_here
AI_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
AI_MODEL_ID=your_model_endpoint_id

# 方案B：文生图 —— Stable Diffusion（https://platform.stability.ai/）
STABLE_DIFFUSION_API_KEY=your_stable_diffusion_api_key

# 方案B：文生图 —— 豆包文生图（火山引擎，需单独开通）
DOUBAO_IMAGE_API_KEY=your_doubao_image_api_key
DOUBAO_IMAGE_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# FastAPI 服务
APP_HOST=0.0.0.0
APP_PORT=8000

# 视频帧存储根目录（按实际路径修改）
FRAMES_BASE_DIR=./frames
